{
  "manifest_version": 3,
  "name": "Teams Recording Downloader",
  "version": "2.1",
  "description": "Download Microsoft Teams / SharePoint Stream meeting recordings (in-browser, decrypts AES-128 segments).",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.sharepoint.com/*",
    "https://*.svc.ms/*",
    "https://teams.microsoft.com/*",
    "https://teams.cloud.microsoft/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.sharepoint.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*"
      ],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.sharepoint.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_icon": {
      "128": "icons/team_lit.png"
    }
  },
  "icons": {
    "128": "icons/team_unlit.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["mux-worker.js"],
      "matches": [
        "https://*.sharepoint.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.cloud.microsoft/*"
      ]
    }
  ]
}
